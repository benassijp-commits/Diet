{
  "hosting": {
    "site": "dieta-e6bee",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      ".obsidian/**",
      "**/node_modules/**",
      "backup-*",
      "backup-*/**",
      "data/backups/**",
      "tools/**",
      "00_AI_CONTEXT_FOR_CODEX.md",
      "Diet_App_AI_Guide_Obsidian.md",
      "diff-ultimo-commit.txt",
      "ROADMAP_USER_STORIES.md",
      "DATABASE_SCHEMA.md"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
