rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /globalFoods/{foodId} {
      allow read: if resource.data.status == "approved";
      allow write: if false;
    }

    match /users/{uid}/state/{docId} {
      allow read, write: if ownsUserDoc(uid);
    }

    match /users/{uid}/notificationTokens/{tokenId} {
      allow read, write: if ownsUserDoc(uid);
    }

    match /users/{uid}/scheduledNotifications/{notificationId} {
      allow read, write: if ownsUserDoc(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
